<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. Full-screen background, crops to fit without distortion -->
    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/wood" />

    <!-- 2. Message board, scales to 85% of screen width and 80% of screen height -->
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.8"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.85"
        app:srcCompat="@drawable/msg8" />

    <!-- 3. Title, constrained relative to the message board -->

    <!-- 4. This Guideline creates a vertical line to separate the header from the content -->

    <TextView
        android:id="@+id/textView3"
        android:layout_width="210dp"
        android:layout_height="55dp"
        android:fontFamily="@font/alagard"
        android:text="Leaderboard"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        app:layout_constraintBottom_toBottomOf="@+id/imageView2"
        app:layout_constraintEnd_toEndOf="@+id/imageView2"
        app:layout_constraintStart_toStartOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="@+id/imageView2"
        app:layout_constraintVertical_bias="0.051"
        tools:text="Leaderboard" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="200dp" />

    <!-- 5. Use a chain to automatically space the column TextViews -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/leaderboard_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="@+id/imageView2"
        app:layout_constraintEnd_toEndOf="@+id/imageView2"
        app:layout_constraintStart_toStartOf="@+id/imageView2"
        app:layout_constraintTop_toBottomOf="@+id/textView3">

        <!-- Column 1: NAME -->
        <TextView
            android:id="@+id/leaderboardText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fontFamily="@font/alagard"
            android:gravity="top|center_horizontal"
            android:text="NAME\n________"
            android:textColor="#E7E6E6"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/timeText"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Column 2: TIME -->
        <TextView
            android:id="@+id/timeText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fontFamily="@font/alagard"
            android:gravity="top|center_horizontal"
            android:text="TIME\n________"
            android:textColor="#E7E6E6"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/lootText"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/leaderboardText"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Column 3: LOOT -->
        <TextView
            android:id="@+id/lootText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fontFamily="@font/alagard"
            android:gravity="top|center_horizontal"
            android:text="LOOT\n________"
            android:textColor="#E7E6E6"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/timeText"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>