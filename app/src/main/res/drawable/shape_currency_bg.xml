<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- This creates the rounded "pill" look -->
    <corners android:radius="20dp" />

    <!-- This defines the base color (which can be tinted in your layout) -->
    <solid android:color="#FFFFFF" />

    <!-- Optional: Add a light stroke/border to make it pop -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" />

    <!-- Optional: Internal spacing -->
    <padding
        android:bottom="4dp"
        android:left="12dp"
        android:right="12dp"
        android:top="4dp" />
</shape>